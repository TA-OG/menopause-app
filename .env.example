# ─────────────────────────────────────────────────────────────
# SUPABASE
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─────────────────────────────────────────────────────────────
# STRIPE
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create these in Stripe dashboard
STRIPE_PRICE_GBP_MONTHLY=price_...   # £7.99/month UK
STRIPE_PRICE_USD_MONTHLY=price_...   # $9.99/month US

# ─────────────────────────────────────────────────────────────
# EMAIL — RESEND
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@menopause-app.com

# ─────────────────────────────────────────────────────────────
# PUSH NOTIFICATIONS — WEB PUSH / VAPID
# ─────────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:hello@menopause-app.com

# ─────────────────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=menopause-app
CRON_SECRET=generate_a_random_secret_here
